# ============================
# 鉴权配置
# ============================

# 客户端访问代理时的鉴权 Key（可选）
# 填写后客户端需通过 Authorization: Bearer <key> 或 api-key / x-api-key 头部携带
PROXY_API_KEY=

# Ops 运维界面密码（可选）
# 填写后 /ops 路由需要密码才能访问（支持停机、重启、运行时配置修改）
# 留空则不启用运维界面
OPS_PASSWORD=

# ============================
# 服务器配置
# ============================
PORT=3000
HOST=0.0.0.0
MAX_BODY_SIZE=10mb

# ============================
# 上游 MiMo API 配置
# ============================

# MiMo API Key（主代理必填；仅使用 token-plan 时可留空）
MIMO_API_KEY=

# OpenAI 格式 Base URL
MIMO_BASE_URL=https://api.xiaomimimo.com
# Anthropic 格式 Base URL
ANTHROPIC_BASE_URL=https://api.xiaomimimo.com/anthropic

# 启用的真实模型（逗号分隔）
# 可选：mimo-v2-flash / mimo-v2-pro / mimo-v2-omni / mimo-v2.5 / mimo-v2.5-pro
# 默认全开
MIMO_ENABLED_MODELS=mimo-v2-flash,mimo-v2-pro,mimo-v2-omni,mimo-v2.5,mimo-v2.5-pro

# 上游请求超时（毫秒）
UPSTREAM_TIMEOUT_MS=120000

# ============================
# Token-Plan 透传代理（可选）
# ============================
# 启用后在 /token-plan 路径下挂载透传路由，不做虚拟模型映射
TOKEN_PLAN_ENABLED=false

# 客户端访问 token-plan 时的鉴权 Key（留空不启用）
TOKEN_PLAN_PROXY_API_KEY=
# 上游 API Key（留空则不携带鉴权）
TOKEN_PLAN_MIMO_API_KEY=
# OpenAI 格式 Base URL（无需带 /v1，代理自动拼接）
TOKEN_PLAN_BASE_URL=https://token-plan-cn.xiaomimimo.com
# Anthropic 格式 Base URL（无需带 /v1，代理自动拼接）
TOKEN_PLAN_ANTHROPIC_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic

# ============================
# 联网搜索配置（search 系列模型使用）
# ============================
WEB_SEARCH_MAX_KEYWORD=3
WEB_SEARCH_FORCE_SEARCH=true
WEB_SEARCH_LIMIT=3
WEB_SEARCH_COUNTRY=China
WEB_SEARCH_REGION=Beijing
WEB_SEARCH_CITY=Beijing

# ============================
# 监控存储配置
# ============================
# 存储后端：memory / sqlite
MONITOR_STORAGE=memory
MONITOR_SQLITE_PATH=./data/monitor.db
MONITOR_RETENTION_DAYS=30
MONITOR_FLUSH_INTERVAL_MS=200
MONITOR_FLUSH_BATCH_SIZE=100
MONITOR_QUEUE_MAX_SIZE=10000

# ============================
# 调试模式（可选）
# ============================
# 开启后记录完整请求/响应体到内存，提供 /debug Web UI
DEBUG_ENABLED=false
DEBUG_MAX_RECORDS=500
# 单条记录最大 body 大小（字节），超过截断
DEBUG_MAX_BODY_SIZE=1048576
# 单条记录最大媒体缓存大小（字节）
DEBUG_MAX_MEDIA_BYTES=10485760

# ============================
# 日志级别: error | warn | info | debug
# ============================
LOG_LEVEL=info
