# ============================
# Provider Config Directory
# ============================
# Directory containing provider YAML configs (default: ./config/provider/)
# CONFIG_DIR=./config/provider/

# ============================
# Provider API Keys
# ============================

# MiMo API Key (required for MiMo provider)
MIMO_API_KEY=

# MiMo Token-Plan API Key (required for token-plan provider)
TOKEN_PLAN_MIMO_API_KEY=

# DeepSeek API Key (required for DeepSeek provider)
DEEPSEEK_API_KEY=

# ============================
# Proxy Authentication
# ============================

# Client access key (optional)
# When set, clients must provide via Authorization: Bearer <key>, api-key, or x-api-key header
PROXY_API_KEY=

# Ops UI password (optional)
# When set, /ops routes require password for access
OPS_PASSWORD=

# ============================
# Server Configuration
# ============================
PORT=3000
HOST=0.0.0.0

# Maximum JSON body size (default: 100mb)
# BODY_SIZE_LIMIT=100mb

# ============================
# Monitor Storage
# ============================
MONITOR_STORAGE=memory
MONITOR_SQLITE_PATH=./data/monitor.db
MONITOR_RETENTION_DAYS=30
MONITOR_FLUSH_INTERVAL_MS=200
MONITOR_FLUSH_BATCH_SIZE=100
MONITOR_QUEUE_MAX_SIZE=10000

# ============================
# Debug Mode (optional)
# ============================
DEBUG_ENABLED=false
DEBUG_MAX_RECORDS=500
DEBUG_MAX_BODY_SIZE=1048576
DEBUG_MAX_MEDIA_BYTES=10485760

# ============================
# Log Level: error | warn | info | debug
# ============================
LOG_LEVEL=info
