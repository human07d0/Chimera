{
  "name": "mimo-proxy",
  "version": "1.4.1",
  "description": "OpenAI & Anthropic-compatible proxy for Xiaomi MiMo API with feature preset models",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc && node scripts/copy-static.cjs && pnpm run build:ops",
    "build:ops": "vite build --config vite.config.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ops:config": "node scripts/test-ops-config.cjs",
    "test:ops": "npm run build && node scripts/test-ops-config.cjs",
    "test:monitor": "npm run build && node scripts/monitor-checks.cjs",
    "test:models": "npm run build && node scripts/test-all-models.cjs",
    "bun:build": "npx -y bun@latest build src/index.ts --outdir=dist-bun --target=bun --external vite --external lightningcss --external postcss",
    "bun:start": "npx -y bun@latest run dist-bun/index.js"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@types/sql.js": "^1.4.9",
    "bun-types": "^1.2.0",
    "lightningcss": "^1.32.0",
    "nodemon": "^3.1.7",
    "postcss": "^8.5.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite": "^6.2.0",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
