{
  "name": "mimo-proxy",
  "version": "1.0.0",
  "description": "OpenAI-compatible proxy for Xiaomi MiMo API with feature preset models",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc && node scripts/copy-static.cjs",
    "check:native:sqlite3": "node scripts/check-sqlite3-native.cjs",
    "prestart": "node scripts/check-sqlite3-native.cjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test:monitor": "npm run build && node scripts/monitor-checks.cjs"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/sqlite3": "^3.1.11",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

