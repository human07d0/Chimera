{
  "name": "mimo-proxy",
  "version": "1.0.0",
  "description": "OpenAI-compatible proxy for Xiaomi MiMo API with feature preset models",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc && node scripts/copy-static.cjs && pnpm run build:ops",
    "build:ops": "vite build --config vite.config.ts",
    "check:native:sqlite3": "node scripts/check-sqlite3-native.cjs",
    "prestart": "node scripts/check-sqlite3-native.cjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ops:config": "node scripts/test-ops-config.cjs",
    "test:ops": "npm run build && node scripts/test-ops-config.cjs",
    "test:monitor": "npm run build && node scripts/monitor-checks.cjs",
    "test:models": "npm run build && node scripts/test-all-models.cjs"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite": "^6.2.0",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}

